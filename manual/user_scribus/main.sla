        <PAGEOBJECT XPOS="142.094488188976" YPOS="729.685039370079" OwnPage="1" ItemID="1079524699" PTYPE="4" WIDTH="756.621441550575" HEIGHT="37.2047244094488" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L756.621 0 L756.621 37.2047 L0 37.2047 L0 0 Z" copath="M0 0 L756.621 0 L756.621 37.2047 L0 37.2047 L0 0 Z" gXpos="142.094488188976" gYpos="729.685039370079" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Arplus is 14 HP wide. It is powered by a +12V/−12V 2×5 connector. The red stripe (−12V) has to be connected on the side of the board marked with the"/>
                <para/>
                <ITEXT CH="white line. The module must be mounted in a eurorack case."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
