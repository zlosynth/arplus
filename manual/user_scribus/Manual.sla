        <PAGEOBJECT XPOS="161.653543307087" YPOS="472.110884082527" OwnPage="0" ItemID="1126653881" PTYPE="4" WIDTH="304.015748031496" HEIGHT="127.396989933221" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L304.016 0 L304.016 127.397 L0 127.397 L0 0 Z" copath="M0 0 L304.016 0 L304.016 127.397 L0 127.397 L0 0 Z" gXpos="161.653543307087" gYpos="472.110884082527" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle FCOLOR="White"/>
                <ITEXT FCOLOR="White" CH="- Karplus-Strong string synthesis with 8-voice polyphony"/>
                <para/>
                <ITEXT FCOLOR="White" CH="- 31 different scales and chords of up to 8 notes"/>
                <para/>
                <ITEXT FCOLOR="White" CH="- CV-controllable arpeggiator patterns"/>
                <para/>
                <ITEXT FCOLOR="White" CH="- Quantized 1V/oct output"/>
                <para/>
                <ITEXT FCOLOR="White" CH="- Dedicated output channel for the root note"/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
