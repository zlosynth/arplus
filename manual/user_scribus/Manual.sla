        <PAGEOBJECT XPOS="143.173834039976" YPOS="853.877952755906" OwnPage="1" ItemID="1133811721" PTYPE="4" WIDTH="756.621441550575" HEIGHT="37.2047244094488" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L756.621 0 L756.621 37.2047 L0 37.2047 L0 0 Z" copath="M0 0 L756.621 0 L756.621 37.2047 L0 37.2047 L0 0 Z" gXpos="143.173834039975" gYpos="853.877952755906" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Turn all the knobs to the initial position illustrated on the front page of this manual. Click the "/>
                <ITEXT Unicode="25" COBJ="752559582"/>
                <ITEXT CH=" (ARP), GROUP, and SCALE buttons until each of them"/>
                <para/>
                <ITEXT CH="lights up the top-most LED. Connect a clock source to the TRIGGER input, and connect the ROOT output to your mixer."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
