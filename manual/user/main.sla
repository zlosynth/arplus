        <PAGEOBJECT XPOS="143.173834039976" YPOS="7082.44094488189" OwnPage="11" ItemID="163616998" PTYPE="4" WIDTH="356.511205330103" HEIGHT="279.035433070867" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L356.511 0 L356.511 279.035 L0 279.035 L0 0 Z" copath="M0 0 L356.511 0 L356.511 279.035 L0 279.035 L0 0 Z" gXpos="143.173834039975" gYpos="5811.88976377952" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="To improve tracking of 1V/oct TONE input, calibrate the module:"/>
                <para ALIGN="0"/>
                <para ALIGN="0"/>
                <ITEXT CH="   1. While holding the RESET button, connect a CV source to TONE."/>
                <para ALIGN="0"/>
                <ITEXT CH="   2. Play note C on the CV source and press the RESET button."/>
                <para ALIGN="0"/>
                <ITEXT CH="   3. Play C one octave higher and press the RESET button again."/>
                <para ALIGN="0"/>
                <ITEXT CH="   4. Successful calibration is confirmed by all LEDs litting up."/>
                <para ALIGN="0"/>
                <para ALIGN="0"/>
                <para ALIGN="0"/>
                <ITEXT CH="To improve the accuracy of the 1V/oct QUANT. output, calibrate it against the source that was previously used to calibrate the TONE input:"/>
                <para ALIGN="0"/>
                <para ALIGN="0"/>
                <ITEXT CH="   1. Complete TONE input calibration."/>
                <para ALIGN="0"/>
                <ITEXT CH="   2. Press down the "/>
                <ITEXT Unicode="25" COBJ="752559582"/>
                <ITEXT CH=" (ARP type) button."/>
                <para ALIGN="0"/>
                <ITEXT CH="   3. Connect a cable between the QUANT. output and TONE input."/>
                <para ALIGN="0"/>
                <ITEXT CH="   4. Release the "/>
                <ITEXT Unicode="25" COBJ="752559582"/>
                <ITEXT CH=" (ARP) button."/>
                <trail ALIGN="0"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="143.173834039976" YPOS="7398.32677165355" OwnPage="11" ItemID="163631110" PTYPE="4" WIDTH="233.858267716535" HEIGHT="26.3068872720023" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L233.858 0 L233.858 26.3069 L0 26.3069 L0 0 Z" copath="M0 0 L233.858 0 L233.858 26.3069 L0 26.3069 L0 0 Z" gXpos="143.173834039975" gYpos="6127.77559055118" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
