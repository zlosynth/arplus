        <PAGEOBJECT XPOS="531.738340399758" YPOS="7289.19291338584" OwnPage="11" ItemID="164288038" PTYPE="4" WIDTH="370.15142337977" HEIGHT="239.704724409436" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L370.151 0 L370.151 239.705 L0 239.705 L0 0 Z" copath="M0 0 L370.151 0 L370.151 239.705 L0 239.705 L0 0 Z" gXpos="531.738340399757" gYpos="6018.64173228347" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Kudos to all the eurorack, DSP, and embedded programming communities online. Here are some of the people who helped shape this module:"/>
                <para/>
                <para/>
                <ITEXT CH="Tomas Niesner, for his extensive testing and thoughtful feedback on the interface, features, and functionality. His insights shaped much of this module."/>
                <para/>
                <para/>
                <ITEXT CH="Jan from Bremen, whose feedback and clever suggestions to the manual of Kaseta (sorry I did not get to implement those) inspired the approach I took with this manual."/>
                <trail/>
            </StoryText>
        </PAGEOBJECT>
